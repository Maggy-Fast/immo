# .env pour la production AWS
APP_NAME="IMMO Backend"
APP_ENV=production
APP_KEY=base64:VOTRE_CLE_APPLICATION_ICI
APP_DEBUG=false
APP_URL=https://votre-domaine-aws.com

APP_TIMEZONE=UTC
APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=votre-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=immo_production
DB_USERNAME=immo_user
DB_PASSWORD=votre_mot_de_passe_securise

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=votre-elasticache-endpoint.cache.amazonaws.com
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=VOTRE_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=VOTRE_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=votre-s3-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

# Configuration Twilio WhatsApp
TWILIO_SID=VOTRE_TWILIO_SID
TWILIO_AUTH_TOKEN=VOTRE_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Configuration mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
